{
  "manifest_version": 3,
  "name": "Instagram Unfollower & Pending Request Canceler",
  "short_name": "IG Unfollow & Cancel",
  "version": "2.2.1",
  "description": "Easily cancel pending Instagram follow requests and unfollow profiles automatically. Bulk management tool with human-like delays.",
  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "alarms",
    "activeTab"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "host_permissions": [
    "https://instagram.com/*",
    "https://*.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pending Request Canceler"
  },
  "content_scripts": [
    {
      "matches": [
        "https://instagram.com/*",
        "https://*.instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
